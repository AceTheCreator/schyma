{
  "extends": "../../tsconfig.base.json",
  "include": ["src", "../playground/src/declaration.d.ts"],
  "exclude": ["dist", "node_modules"],
  "compilerOptions": {
    "moduleResolution": "bundler",
    "module": "esnext",
    "target": "es6",
    "rootDir": "./src",
    "outDir": "./dist/esm",
    "types": ["jest", "node"],
    "plugins": [{ "name": "typescript-plugin-css-modules" }]
  }
}